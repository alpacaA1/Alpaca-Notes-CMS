doctype
html(lang="zh-CN")
    head
        include head

    body
        div#stage.container
            div.row
                include sidebar
                div#main-container.col-sm-9.col-xs-12.main-container.fadeInTop

                    block content
                    div.visible-xs.site-bottom-footer
                        include footer

        button#back-to-top.back-to-top(type="button", aria-label="返回顶部", title="返回顶部")
            include icons
            +icon('angle-up')

        script(src= url_for('js/typography.js'), defer)
