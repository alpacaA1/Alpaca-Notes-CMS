extends partial/layout

block site_title
    != page.title + " · " + config.title

block description
    meta(name="description", content="每天固定随机 15 条知识点，适合手机快速查看。")
    meta(name="robots", content="noindex,nofollow")

block content
    .autopagerize_page_element
        .content
            style.
                #main-container {
                    overflow: visible;
                }

                .today-knowledge {
                    --tk-bg: #f5efe7;
                    --tk-paper: rgba(255, 252, 247, 0.94);
                    --tk-paper-strong: #fffdfa;
                    --tk-line: rgba(90, 67, 45, 0.14);
                    --tk-line-strong: rgba(90, 67, 45, 0.24);
                    --tk-text: #2e251d;
                    --tk-muted: #6f6255;
                    --tk-soft: #8d7c69;
                    --tk-accent: #a66b2c;
                    --tk-accent-soft: rgba(166, 107, 44, 0.12);
                    --tk-shadow: 0 18px 40px rgba(66, 42, 20, 0.08);
                    max-width: 820px;
                    margin: 0 auto;
                    padding: 28px 0 56px;
                    color: var(--tk-text);
                }

                .today-knowledge__hero {
                    display: grid;
                    gap: 10px;
                    margin-bottom: 18px;
                    padding: 24px 22px;
                    border: 1px solid var(--tk-line);
                    border-radius: 24px;
                    background: linear-gradient(145deg, rgba(255, 251, 245, 0.96), rgba(246, 236, 221, 0.88));
                    box-shadow: var(--tk-shadow);
                }

                .today-knowledge__hero-eyebrow {
                    margin: 0;
                    color: var(--tk-accent);
                    font-size: 12px;
                    font-weight: 700;
                    letter-spacing: 0.14em;
                    text-transform: uppercase;
                }

                .today-knowledge__hero-title {
                    margin: 0;
                    font-size: clamp(28px, 4vw, 40px);
                    line-height: 1.1;
                }

                .today-knowledge__hero-desc {
                    margin: 0;
                    max-width: 34em;
                    color: var(--tk-muted);
                    line-height: 1.8;
                }

                .today-knowledge__hero-meta {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 10px;
                    align-items: center;
                }

                .today-knowledge__hero-chip {
                    display: inline-flex;
                    align-items: center;
                    padding: 7px 12px;
                    border: 1px solid rgba(90, 67, 45, 0.12);
                    border-radius: 999px;
                    background: rgba(255, 252, 247, 0.74);
                    color: var(--tk-soft);
                    font-size: 12px;
                    font-weight: 600;
                    letter-spacing: 0.05em;
                }

                .today-knowledge__state {
                    padding: 30px 24px;
                    border: 1px solid var(--tk-line);
                    border-radius: 24px;
                    background: var(--tk-paper);
                    box-shadow: var(--tk-shadow);
                    color: var(--tk-muted);
                }

                .today-knowledge__deck-status {
                    display: none;
                }

                .today-knowledge__list {
                    display: grid;
                    gap: 18px;
                }

                .today-knowledge__card {
                    padding: 24px 22px 26px;
                    border: 1px solid var(--tk-line);
                    border-radius: 24px;
                    background: var(--tk-paper);
                    box-shadow: var(--tk-shadow);
                }

                .today-knowledge__card-top {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 12px;
                    margin-bottom: 14px;
                }

                .today-knowledge__order {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    min-width: 38px;
                    height: 38px;
                    padding: 0 11px;
                    border-radius: 999px;
                    background: var(--tk-accent-soft);
                    color: var(--tk-accent);
                    font-size: 14px;
                    font-weight: 700;
                    letter-spacing: 0.08em;
                }

                .today-knowledge__date {
                    margin: 0;
                    color: var(--tk-soft);
                    font-size: 13px;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                }

                .today-knowledge__title {
                    margin: 0;
                    font-size: clamp(24px, 3vw, 32px);
                    line-height: 1.35;
                }

                .today-knowledge__preview {
                    margin: 12px 0 0;
                    color: var(--tk-muted);
                    line-height: 1.85;
                    font-size: clamp(16px, 2vw, 18px);
                    display: -webkit-box;
                    -webkit-line-clamp: 4;
                    -webkit-box-orient: vertical;
                    overflow: hidden;
                }

                .today-knowledge__details {
                    margin-top: 18px;
                    padding-top: 18px;
                    border-top: 1px solid rgba(90, 67, 45, 0.09);
                }

                .today-knowledge__details-summary {
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    color: var(--tk-accent);
                    font-size: 13px;
                    font-weight: 700;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                    cursor: pointer;
                    list-style: none;
                }

                .today-knowledge__details-summary::-webkit-details-marker {
                    display: none;
                }

                .today-knowledge__details-summary::after {
                    content: '+';
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    width: 20px;
                    height: 20px;
                    border-radius: 50%;
                    background: rgba(166, 107, 44, 0.1);
                    font-size: 14px;
                    line-height: 1;
                }

                .today-knowledge__details[open] .today-knowledge__details-summary::after {
                    content: '−';
                }

                .today-knowledge__details-body {
                    display: grid;
                    gap: 14px;
                    margin-top: 16px;
                }

                .today-knowledge__section {
                    display: grid;
                    gap: 8px;
                }

                .today-knowledge__section-label {
                    margin: 0;
                    color: var(--tk-accent);
                    font-size: 12px;
                    font-weight: 700;
                    letter-spacing: 0.1em;
                    text-transform: uppercase;
                }

                .today-knowledge__body {
                    margin: 0;
                    white-space: pre-wrap;
                    word-break: break-word;
                    line-height: 1.9;
                    font-size: clamp(16px, 1.95vw, 18px);
                    color: var(--tk-text);
                }

                .today-knowledge__body--quote {
                    padding: 14px 16px;
                    border-left: 3px solid rgba(166, 107, 44, 0.42);
                    border-radius: 0 16px 16px 0;
                    background: rgba(166, 107, 44, 0.06);
                }

                .today-knowledge__card--active {
                    pointer-events: auto;
                }

                .today-knowledge__pager {
                    display: none;
                    align-items: center;
                    justify-content: center;
                    gap: 14px;
                    margin-top: 18px;
                }

                .today-knowledge__pager-button {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    width: 38px;
                    height: 38px;
                    border: 1px solid var(--tk-line-strong);
                    border-radius: 999px;
                    background: var(--tk-paper-strong);
                    color: var(--tk-accent);
                    font-size: 20px;
                    line-height: 1;
                    cursor: pointer;
                    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
                }

                .today-knowledge__pager-button:hover:not(:disabled) {
                    transform: translateY(-1px);
                    border-color: rgba(166, 107, 44, 0.35);
                    box-shadow: 0 10px 24px rgba(66, 42, 20, 0.08);
                }

                .today-knowledge__pager-button:disabled {
                    cursor: default;
                    opacity: 0.38;
                    box-shadow: none;
                }

                .today-knowledge__pager-current {
                    min-width: 58px;
                    text-align: center;
                    color: var(--tk-soft);
                    font-size: 15px;
                    font-weight: 600;
                    letter-spacing: 0.08em;
                }

                @media (min-width: 768px) {
                    .today-knowledge--wheel-deck {
                        min-height: calc(100vh - 72px);
                        display: flex;
                        flex-direction: column;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__deck-status {
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        gap: 12px;
                        margin-bottom: 14px;
                        color: var(--tk-soft);
                        font-size: 13px;
                        letter-spacing: 0.08em;
                        text-transform: uppercase;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__deck-status::before {
                        content: 'Desktop';
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        padding: 5px 10px;
                        border-radius: 999px;
                        background: rgba(255, 252, 247, 0.7);
                        border: 1px solid rgba(90, 67, 45, 0.08);
                        color: var(--tk-accent);
                        font-size: 11px;
                        font-weight: 700;
                        letter-spacing: 0.14em;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__list--wheel-deck {
                        position: relative;
                        flex: 1;
                        min-height: clamp(520px, 74vh, 760px);
                        overflow: hidden;
                        overscroll-behavior: contain;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__card {
                        position: absolute;
                        inset: 0;
                        margin: 0;
                        padding: 28px 26px 30px;
                        overflow: auto;
                        opacity: 0;
                        transform: translate3d(0, 44px, 0) scale(0.985);
                        transition: opacity 220ms ease, transform 260ms ease;
                        pointer-events: none;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__card--active {
                        opacity: 1;
                        transform: translate3d(0, 0, 0) scale(1);
                    }
                }

                @media (prefers-reduced-motion: reduce) {
                    .today-knowledge--wheel-deck .today-knowledge__card {
                        transition: none;
                    }
                }

                @media (max-width: 767px) {
                    #side-bar {
                        padding: 20px 22px 0;
                    }

                    #site-nav {
                        display: none;
                    }

                    #main-container {
                        padding: 8px 22px 40px;
                    }

                    .site-bottom-footer {
                        display: none !important;
                    }

                    .today-knowledge {
                        padding: 0 0 40px;
                    }

                    .today-knowledge__hero {
                        padding: 20px 18px;
                    }

                    .today-knowledge__card {
                        padding: 22px 18px 24px;
                        border-radius: 20px;
                    }

                    .today-knowledge__title {
                        font-size: 24px;
                    }

                    .today-knowledge__list--mobile-deck {
                        display: block;
                    }

                    .today-knowledge__preview,
                    .today-knowledge__body {
                        font-size: 16px;
                        line-height: 1.9;
                    }

                    .today-knowledge__pager {
                        display: flex;
                    }
                }
            .today-knowledge#today-knowledge-app(data-data-path=url_for('today-knowledge/data.json') data-timezone=(config.timezone || 'Asia/Shanghai'))
                header.today-knowledge__hero
                    p.today-knowledge__hero-eyebrow Daily Notes
                    h1.today-knowledge__hero-title 今日知识点
                    p.today-knowledge__hero-desc 每天从知识库里固定随机抽 15 条，先快速过一遍，再按需要展开细看。
                    .today-knowledge__hero-meta
                        span.today-knowledge__hero-chip#today-knowledge-hero-date 今日加载中
                        span.today-knowledge__hero-chip#today-knowledge-hero-count 0 / 15
                .today-knowledge__state#today-knowledge-state 正在加载知识点…
                .today-knowledge__deck-status#today-knowledge-deck-status(hidden)
                .today-knowledge__list#today-knowledge-list(hidden)
                .today-knowledge__pager#today-knowledge-pager(hidden)
                    button.today-knowledge__pager-button#today-knowledge-pager-prev(type="button" aria-label="上一条知识点") &lt;
                    span.today-knowledge__pager-current#today-knowledge-pager-current
                    button.today-knowledge__pager-button#today-knowledge-pager-next(type="button" aria-label="下一条知识点") &gt;
            script(src=url_for('js/today-knowledge.js'))
