extends partial/layout

block site_title
    != page.title + " · " + config.title

block description
    meta(name="description", content="每天固定随机 15 条知识点，适合手机快速查看。")
    meta(name="robots", content="noindex,nofollow")

block content
    .autopagerize_page_element
        .content
            style.
                .today-knowledge {
                    --tk-bg: #f5efe7;
                    --tk-paper: rgba(255, 252, 247, 0.94);
                    --tk-paper-strong: #fffdfa;
                    --tk-line: rgba(90, 67, 45, 0.14);
                    --tk-line-strong: rgba(90, 67, 45, 0.24);
                    --tk-text: #2e251d;
                    --tk-muted: #6f6255;
                    --tk-soft: #8d7c69;
                    --tk-accent: #a66b2c;
                    --tk-accent-soft: rgba(166, 107, 44, 0.12);
                    --tk-shadow: 0 18px 40px rgba(66, 42, 20, 0.08);
                    max-width: 820px;
                    margin: 0 auto;
                    padding: 28px 0 56px;
                    color: var(--tk-text);
                }

                .today-knowledge__hero {
                    position: relative;
                    overflow: hidden;
                    margin-bottom: 24px;
                    padding: 28px 24px;
                    border: 1px solid var(--tk-line);
                    border-radius: 28px;
                    background:
                        radial-gradient(circle at top right, rgba(166, 107, 44, 0.16), transparent 34%),
                        linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 248, 240, 0.92));
                    box-shadow: var(--tk-shadow);
                }

                .today-knowledge__eyebrow {
                    margin: 0 0 10px;
                    color: var(--tk-accent);
                    font-size: 12px;
                    font-weight: 700;
                    letter-spacing: 0.16em;
                    text-transform: uppercase;
                }

                .today-knowledge__hero h1 {
                    margin: 0;
                    font-size: clamp(32px, 7vw, 46px);
                    line-height: 1.02;
                }

                .today-knowledge__hero p {
                    margin: 14px 0 0;
                    color: var(--tk-muted);
                    line-height: 1.8;
                }

                .today-knowledge__hero-meta {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 10px;
                    margin-top: 18px;
                }

                .today-knowledge__pill {
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    min-height: 36px;
                    padding: 0 14px;
                    border: 1px solid var(--tk-line);
                    border-radius: 999px;
                    background: rgba(255, 255, 255, 0.66);
                    color: var(--tk-muted);
                    font-size: 14px;
                }

                .today-knowledge__hint {
                    margin: 0 0 18px;
                    padding: 14px 16px;
                    border: 1px dashed var(--tk-line-strong);
                    border-radius: 18px;
                    background: rgba(255, 255, 255, 0.52);
                    color: var(--tk-muted);
                    line-height: 1.75;
                }

                .today-knowledge__state {
                    padding: 30px 24px;
                    border: 1px solid var(--tk-line);
                    border-radius: 24px;
                    background: var(--tk-paper);
                    box-shadow: var(--tk-shadow);
                    color: var(--tk-muted);
                }

                .today-knowledge__list {
                    display: grid;
                    gap: 18px;
                }

                .today-knowledge__card {
                    padding: 22px 20px;
                    border: 1px solid var(--tk-line);
                    border-radius: 24px;
                    background: var(--tk-paper);
                    box-shadow: var(--tk-shadow);
                }

                .today-knowledge__card-top {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 12px;
                    margin-bottom: 14px;
                }

                .today-knowledge__order {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    width: 34px;
                    height: 34px;
                    border-radius: 50%;
                    background: var(--tk-accent-soft);
                    color: var(--tk-accent);
                    font-size: 14px;
                    font-weight: 700;
                }

                .today-knowledge__date {
                    color: var(--tk-soft);
                    font-size: 13px;
                }

                .today-knowledge__title {
                    margin: 0;
                    font-size: 22px;
                    line-height: 1.4;
                }

                .today-knowledge__desc {
                    margin: 10px 0 0;
                    color: var(--tk-muted);
                    line-height: 1.8;
                }

                .today-knowledge__section {
                    margin-top: 16px;
                    padding-top: 16px;
                    border-top: 1px solid rgba(90, 67, 45, 0.09);
                }

                .today-knowledge__section-label {
                    margin: 0 0 8px;
                    color: var(--tk-accent);
                    font-size: 12px;
                    font-weight: 700;
                    letter-spacing: 0.1em;
                    text-transform: uppercase;
                }

                .today-knowledge__quote,
                .today-knowledge__note {
                    margin: 0;
                    white-space: pre-wrap;
                    word-break: break-word;
                    line-height: 1.9;
                }

                .today-knowledge__quote {
                    padding: 14px 16px;
                    border-left: 3px solid rgba(166, 107, 44, 0.42);
                    border-radius: 0 16px 16px 0;
                    background: rgba(166, 107, 44, 0.06);
                }

                .today-knowledge__note {
                    color: var(--tk-text);
                }

                @media (max-width: 767px) {
                    .today-knowledge {
                        padding: 14px 0 40px;
                    }

                    .today-knowledge__hero {
                        margin-bottom: 18px;
                        padding: 22px 18px;
                        border-radius: 22px;
                    }

                    .today-knowledge__hero h1 {
                        font-size: 34px;
                    }

                    .today-knowledge__card {
                        padding: 18px 16px;
                        border-radius: 20px;
                    }

                    .today-knowledge__title {
                        font-size: 20px;
                    }

                    .today-knowledge__card-top {
                        align-items: flex-start;
                    }
                }
            .today-knowledge#today-knowledge-app(data-data-path=url_for('today-knowledge/data.json') data-timezone=(config.timezone || 'Asia/Shanghai'))
                .today-knowledge__hero
                    p.today-knowledge__eyebrow Daily Knowledge
                    h1 今日知识点
                    p 每天固定随机 15 条。适合在手机上碎片化翻看，今天看过的内容，明天会自动换一批。
                    .today-knowledge__hero-meta
                        span.today-knowledge__pill#today-knowledge-date 正在识别今天的日期…
                        span.today-knowledge__pill#today-knowledge-count 准备抽取今日 15 条
                p.today-knowledge__hint 把这个页面加入手机主屏幕，以后直接点开就能看。页面会按上海时区自动切换当天内容，不需要登录后台。
                .today-knowledge__state#today-knowledge-state 正在加载知识点…
                .today-knowledge__list#today-knowledge-list(hidden)
            script.
                (function () {
                    const app = document.getElementById('today-knowledge-app');
                    if (!app) {
                        return;
                    }

                    const stateNode = document.getElementById('today-knowledge-state');
                    const listNode = document.getElementById('today-knowledge-list');
                    const dateNode = document.getElementById('today-knowledge-date');
                    const countNode = document.getElementById('today-knowledge-count');
                    const dataPath = app.dataset.dataPath;
                    const timeZone = app.dataset.timezone || 'Asia/Shanghai';

                    function escapeHtml(value) {
                        return String(value || '')
                            .replace(/&/g, '&amp;')
                            .replace(/</g, '&lt;')
                            .replace(/>/g, '&gt;')
                            .replace(/"/g, '&quot;')
                            .replace(/'/g, '&#39;');
                    }

                    function pad(value) {
                        return String(value).padStart(2, '0');
                    }

                    function getDateParts(date, zone) {
                        const formatter = new Intl.DateTimeFormat('en-CA', {
                            timeZone: zone,
                            year: 'numeric',
                            month: '2-digit',
                            day: '2-digit',
                        });
                        const parts = formatter.formatToParts(date);
                        const values = {};

                        parts.forEach(function (part) {
                            if (part.type !== 'literal') {
                                values[part.type] = part.value;
                            }
                        });

                        return {
                            year: Number(values.year),
                            month: Number(values.month),
                            day: Number(values.day),
                        };
                    }

                    function getDateKey(date, zone) {
                        const parts = getDateParts(date, zone);
                        return parts.year + '-' + pad(parts.month) + '-' + pad(parts.day);
                    }

                    function formatDisplayDate(date, zone) {
                        const parts = getDateParts(date, zone);
                        return parts.year + '年' + parts.month + '月' + parts.day + '日';
                    }

                    function hashValue(value) {
                        let hash = 2166136261;

                        for (let index = 0; index < value.length; index += 1) {
                            hash ^= value.charCodeAt(index);
                            hash = Math.imul(hash, 16777619);
                        }

                        return hash >>> 0;
                    }

                    function pickDailyItems(items, limit, date, zone) {
                        const seed = getDateKey(date, zone);

                        return items
                            .slice()
                            .sort(function (left, right) {
                                const leftScore = hashValue(seed + ':' + left.path);
                                const rightScore = hashValue(seed + ':' + right.path);

                                if (leftScore !== rightScore) {
                                    return leftScore - rightScore;
                                }

                                return left.path.localeCompare(right.path, 'zh-CN');
                            })
                            .slice(0, Math.max(0, Math.floor(limit)));
                    }

                    function renderSection(label, className, value) {
                        if (!value) {
                            return '';
                        }

                        return (
                            '<section class="today-knowledge__section">' +
                                '<p class="today-knowledge__section-label">' + label + '</p>' +
                                '<p class="' + className + '">' + escapeHtml(value) + '</p>' +
                            '</section>'
                        );
                    }

                    function renderCard(item, index) {
                        const title = escapeHtml(item.title || '未命名知识点');
                        const desc = item.desc ? '<p class="today-knowledge__desc">' + escapeHtml(item.desc) + '</p>' : '';
                        const quote = renderSection('原文摘录', 'today-knowledge__quote', item.quote);
                        const note = renderSection('我的理解', 'today-knowledge__note', item.note || item.content);

                        return (
                            '<article class="today-knowledge__card">' +
                                '<div class="today-knowledge__card-top">' +
                                    '<span class="today-knowledge__order">' + String(index + 1).padStart(2, '0') + '</span>' +
                                    '<span class="today-knowledge__date">' + escapeHtml((item.date || '').slice(0, 10) || '无日期') + '</span>' +
                                '</div>' +
                                '<h2 class="today-knowledge__title">' + title + '</h2>' +
                                desc +
                                quote +
                                note +
                            '</article>'
                        );
                    }

                    function showState(message) {
                        stateNode.textContent = message;
                        stateNode.hidden = false;
                        listNode.hidden = true;
                        listNode.innerHTML = '';
                    }

                    function showList(items) {
                        listNode.innerHTML = items.map(renderCard).join('');
                        listNode.hidden = false;
                        stateNode.hidden = true;
                    }

                    dateNode.textContent = '今天是 ' + formatDisplayDate(new Date(), timeZone);

                    fetch(dataPath, { cache: 'no-store' })
                        .then(function (response) {
                            if (!response.ok) {
                                throw new Error('加载今日知识点数据失败');
                            }

                            return response.json();
                        })
                        .then(function (payload) {
                            const items = Array.isArray(payload.items) ? payload.items : [];

                            if (items.length === 0) {
                                countNode.textContent = '今天还没有可展示的知识点';
                                showState('知识点仓库还是空的，先去后台沉淀几条再来。');
                                return;
                            }

                            const dailyItems = pickDailyItems(items, 15, new Date(), timeZone);
                            countNode.textContent = '今天为你固定展示 ' + dailyItems.length + ' 条';
                            showList(dailyItems);
                        })
                        .catch(function (error) {
                            countNode.textContent = '知识点数据暂时不可用';
                            showState(error instanceof Error ? error.message : '加载知识点失败，请稍后重试。');
                        });
                })();
