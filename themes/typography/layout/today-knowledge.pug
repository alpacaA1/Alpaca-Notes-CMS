extends partial/layout

block site_title
    != page.title + " · " + config.title

block description
    meta(name="description", content="每天固定随机 15 条知识点，适合手机快速查看。")
    meta(name="robots", content="noindex,nofollow")

block content
    .autopagerize_page_element
        .content
            style.
                .today-knowledge {
                    --tk-bg: #f5efe7;
                    --tk-paper: rgba(255, 252, 247, 0.94);
                    --tk-paper-strong: #fffdfa;
                    --tk-line: rgba(90, 67, 45, 0.14);
                    --tk-line-strong: rgba(90, 67, 45, 0.24);
                    --tk-text: #2e251d;
                    --tk-muted: #6f6255;
                    --tk-soft: #8d7c69;
                    --tk-accent: #a66b2c;
                    --tk-accent-soft: rgba(166, 107, 44, 0.12);
                    --tk-shadow: 0 18px 40px rgba(66, 42, 20, 0.08);
                    max-width: 820px;
                    margin: 0 auto;
                    padding: 28px 0 56px;
                    color: var(--tk-text);
                }

                .today-knowledge__state {
                    padding: 30px 24px;
                    border: 1px solid var(--tk-line);
                    border-radius: 24px;
                    background: var(--tk-paper);
                    box-shadow: var(--tk-shadow);
                    color: var(--tk-muted);
                }

                .today-knowledge__deck-status {
                    display: none;
                }

                .today-knowledge__list {
                    display: grid;
                    gap: 18px;
                }

                .today-knowledge__card {
                    padding: 24px 22px 26px;
                    border: 1px solid var(--tk-line);
                    border-radius: 24px;
                    background: var(--tk-paper);
                    box-shadow: var(--tk-shadow);
                }

                .today-knowledge__date {
                    margin: 0 0 16px;
                    color: var(--tk-soft);
                    font-size: 13px;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                }

                .today-knowledge__body {
                    margin: 0;
                    white-space: pre-wrap;
                    word-break: break-word;
                    line-height: 1.95;
                    font-size: clamp(17px, 2.1vw, 20px);
                }

                .today-knowledge__card--active {
                    pointer-events: auto;
                }

                .today-knowledge__pager {
                    display: none;
                    align-items: center;
                    justify-content: center;
                    gap: 14px;
                    margin-top: 18px;
                }

                .today-knowledge__pager-button {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    width: 38px;
                    height: 38px;
                    border: 1px solid var(--tk-line-strong);
                    border-radius: 999px;
                    background: var(--tk-paper-strong);
                    color: var(--tk-accent);
                    font-size: 20px;
                    line-height: 1;
                    cursor: pointer;
                    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
                }

                .today-knowledge__pager-button:hover:not(:disabled) {
                    transform: translateY(-1px);
                    border-color: rgba(166, 107, 44, 0.35);
                    box-shadow: 0 10px 24px rgba(66, 42, 20, 0.08);
                }

                .today-knowledge__pager-button:disabled {
                    cursor: default;
                    opacity: 0.38;
                    box-shadow: none;
                }

                .today-knowledge__pager-current {
                    min-width: 58px;
                    text-align: center;
                    color: var(--tk-soft);
                    font-size: 15px;
                    font-weight: 600;
                    letter-spacing: 0.08em;
                }

                @media (min-width: 768px) {
                    .today-knowledge--wheel-deck {
                        min-height: calc(100vh - 72px);
                        display: flex;
                        flex-direction: column;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__deck-status {
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        gap: 12px;
                        margin-bottom: 14px;
                        color: var(--tk-soft);
                        font-size: 13px;
                        letter-spacing: 0.08em;
                        text-transform: uppercase;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__deck-status::before {
                        content: 'Desktop';
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        padding: 5px 10px;
                        border-radius: 999px;
                        background: rgba(255, 252, 247, 0.7);
                        border: 1px solid rgba(90, 67, 45, 0.08);
                        color: var(--tk-accent);
                        font-size: 11px;
                        font-weight: 700;
                        letter-spacing: 0.14em;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__list--wheel-deck {
                        position: relative;
                        flex: 1;
                        min-height: clamp(520px, 74vh, 760px);
                        overflow: hidden;
                        overscroll-behavior: contain;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__card {
                        position: absolute;
                        inset: 0;
                        margin: 0;
                        padding: 28px 26px 30px;
                        opacity: 0;
                        transform: translate3d(0, 44px, 0) scale(0.985);
                        transition: opacity 220ms ease, transform 260ms ease;
                        pointer-events: none;
                    }

                    .today-knowledge--wheel-deck .today-knowledge__card--active {
                        opacity: 1;
                        transform: translate3d(0, 0, 0) scale(1);
                    }
                }

                @media (prefers-reduced-motion: reduce) {
                    .today-knowledge--wheel-deck .today-knowledge__card {
                        transition: none;
                    }
                }

                @media (max-width: 767px) {
                    .today-knowledge {
                        padding: 14px 0 40px;
                    }

                    .today-knowledge__card {
                        padding: 22px 18px 24px;
                        border-radius: 20px;
                    }

                    .today-knowledge__list--mobile-deck {
                        display: block;
                    }

                    .today-knowledge__body {
                        font-size: 18px;
                        line-height: 1.9;
                    }

                    .today-knowledge__pager {
                        display: flex;
                    }
                }
            .today-knowledge#today-knowledge-app(data-data-path=url_for('today-knowledge/data.json') data-timezone=(config.timezone || 'Asia/Shanghai'))
                .today-knowledge__state#today-knowledge-state 正在加载知识点…
                .today-knowledge__deck-status#today-knowledge-deck-status(hidden)
                .today-knowledge__list#today-knowledge-list(hidden)
                .today-knowledge__pager#today-knowledge-pager(hidden)
                    button.today-knowledge__pager-button#today-knowledge-pager-prev(type="button" aria-label="上一条知识点") &lt;
                    span.today-knowledge__pager-current#today-knowledge-pager-current
                    button.today-knowledge__pager-button#today-knowledge-pager-next(type="button" aria-label="下一条知识点") &gt;
            script(src=url_for('js/today-knowledge.js'))
