{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "admin-app"
  ],
  "scripts": {
    "build": "npm run build:admin && npm run sync:private-content && hexo generate",
    "build:admin": "npm run build --workspace admin-app",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "server": "hexo server",
    "sync:private-content": "node scripts/sync-private-content.js",
    "test:sync-private-content": "node --test scripts/sync-private-content.test.js",
    "test:today-knowledge": "node --test scripts/today-knowledge-page.test.js"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "hexo": "^8.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category-enhance": "^0.1.6",
    "hexo-generator-feed": "^4.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-prism-plugin": "^2.3.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-pug": "^3.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-landscape": "^1.0.0",
    "jsdom": "^25.0.1",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
